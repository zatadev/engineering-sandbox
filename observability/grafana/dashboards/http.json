      "targets": [
        {
          "expr": "histogram_quantile(0.99, sum(rate(http_server_requests_seconds_bucket{job=~\"user-service|order-service|notification-service\"}[1m])) by (le, job))",
          "legendFormat": "{{job}} p99",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(http_server_requests_seconds_bucket{job=~\"user-service|order-service|notification-service\"}[1m])) by (le, job))",
