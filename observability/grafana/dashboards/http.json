          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.50, sum(rate(http_server_requests_seconds_bucket{job=~\"user-service|order-service|notification-service\"}[1m])) by (le, job))",
          "legendFormat": "{{job}} p50",
          "refId": "C"
        }
      ],
      "title": "HTTP Latency Percentiles",
      "type": "timeseries"
    }
