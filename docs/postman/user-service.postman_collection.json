        {
          "name": "Prometheus metrics",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 200', () => pm.response.to.have.status(200));",
                  "pm.test('Response contains JVM metrics', () => {",
                  "    pm.expect(pm.response.text()).to.include('jvm_memory_used_bytes');",
                  "});",
                  "pm.test('Response contains custom user metrics', () => {",
                  "    pm.expect(pm.response.text()).to.include('users_registered_total');",
                  "});;"
                ],
                "type": "text/javascript",
                "packages": {},
