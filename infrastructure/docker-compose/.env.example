# PostgreSQL
POSTGRES_DB=userdb
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me

# Order Service DB
ORDER_DB=orderdb

# JWT
JWT_SECRET=change-me-minimum-32-characters-long
JWT_EXPIRATION_MS=900000

# Spring
SPRING_PROFILES_ACTIVE=dev

# Redis
# No password required for local development.
# Redis authentication will be configured in Phase 8 (Security).

# RabbitMQ
RABBITMQ_USER=change-me
RABBITMQ_PASSWORD=change-me

# Kafka
KAFKA_AUTO_CREATE_TOPICS=true
# Set to false in production : topics must be created explicitly

# Grafana
GRAFANA_USER=admin
GRAFANA_PASSWORD=admin